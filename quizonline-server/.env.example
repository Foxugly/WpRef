# ─── Django core ──────────────────────────────────────────────────────────────
DEBUG=True
SECRET_KEY=replace-with-a-random-secret-of-at-least-32-bytes
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database ─────────────────────────────────────────────────────────────────
# The URL scheme determines the engine:
#   SQLite     : sqlite:///db.sqlite3
#   PostgreSQL : postgresql://user:pass@host:5432/dbname
#   MySQL      : mysql://user:pass@host:3306/dbname
DATABASE_URL=sqlite:///db.sqlite3

# ─── CORS / CSRF ──────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200
# Required in production (must match CORS_ALLOWED_ORIGINS)
CSRF_TRUSTED_ORIGINS=

# ─── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_BASE_URL=http://127.0.0.1:4200
PASSWORD_RESET_FRONTEND_PATH_PREFIX=/user/reset-password

# ─── Email ────────────────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.office365.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=no-reply@example.com

# ─── Celery ───────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1
CELERY_TASK_ALWAYS_EAGER=True

# ─── API ──────────────────────────────────────────────────────────────────────
API_PAGE_SIZE=20

# ─── Uploads ──────────────────────────────────────────────────────────────────
DATA_UPLOAD_MAX_MEMORY_SIZE=10485760
FILE_UPLOAD_MAX_MEMORY_SIZE=10485760
MAX_UPLOAD_FILE_SIZE=10485760
MEDIA_ROOT_DIR=media

# ─── DeepL translation ────────────────────────────────────────────────────────
USE_DEEPL=False
DEEPL_IS_FREE=True
DEEPL_AUTH_KEY=
